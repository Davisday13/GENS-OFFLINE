# GENS-OFFLINE Environment Variables
# Copy this to .env and fill in values

# JWT Secret (REQUERIDO en producción — genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
GENS_JWT_SECRET=your-super-secret-key-change-this

# JWT Expiration (default: 24h)
GENS_JWT_EXPIRES=24h

# CORS allowed origins (comma-separated, default: localhost dev ports)
GENS_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5180,http://localhost:3000

# Server Port (default: 3001)
PORT=3001

# Node Environment
NODE_ENV=development
