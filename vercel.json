{
  "version": 2,
  "buildCommand": "npm run build:erp && npm run copy:dist",
  "outputDirectory": "public",
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
